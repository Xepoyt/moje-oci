parameters:
	universalObjectCratesClasses:
		- Nette\Bridges\ApplicationLatte\DefaultTemplate
		- Nette\Database\Row
		- Nette\Http\SessionSection
		- Nette\Security\SimpleIdentity
		- Nette\Utils\Html

	ignoreErrors:
		-
			# Form event-handler callbacks (onSuccess, onClick, ...) receive data coerced
			# via reflection to whatever type the callback declares (stdClass, array, a DTO),
			# so a data parameter narrower than the declared array|object union is valid at
			# runtime. Gated on the assigned value being a callable.
			identifier: assign.propertyType
			message: '#Property Nette\\Forms\\(Form|Container|Controls\\SubmitButton)::\$on(Success|Error|Submit|Render|Validate|Click|InvalidClick) .* does not accept .*(Closure|callable)\(#'
			reportUnmatched: false

	nette:
		assets:
			mapping: []
		database:
			mapping:
				tables: []


parametersSchema:
	nette: structure([
		assets: structure([
			mapping: arrayOf(string())
		])
		database: structure([
			mapping: structure([
				tables: arrayOf(string(), string())
			])
		])
	])


services:
	# nette/assets
	-
		create: Nette\PHPStan\Assets\MapperTypeResolver(
			mapping: %nette.assets.mapping%
		)
	-
		create: Nette\PHPStan\Assets\GetMapperReturnTypeExtension
		tags: [phpstan.broker.dynamicMethodReturnTypeExtension]
	-
		create: Nette\PHPStan\Assets\MapperGetAssetExtension(
			className: Nette\Assets\FilesystemMapper
		)
		tags: [phpstan.broker.dynamicMethodReturnTypeExtension]
	-
		create: Nette\PHPStan\Assets\MapperGetAssetExtension(
			className: Nette\Assets\ViteMapper
		)
		tags: [phpstan.broker.dynamicMethodReturnTypeExtension]
	-
		create: Nette\PHPStan\Assets\RegistryGetAssetExtension
		tags: [phpstan.broker.dynamicMethodReturnTypeExtension]

	# nette/application
	-
		create: Nette\PHPStan\Application\RethrowAbortExceptionRule
		tags: [phpstan.rules.rule]

	# nette/component-model
	-
		create: Nette\PHPStan\Components\ComponentTreeResolver(@defaultAnalysisParser)
	-
		create: Nette\PHPStan\ComponentModel\GetComponentReturnTypeExtension
		tags: [phpstan.broker.dynamicMethodReturnTypeExtension]

	# nette/database
	-
		create: Nette\PHPStan\Database\TableRowTypeResolver(
			tables: %nette.database.mapping.tables%
		)
	-
		create: Nette\PHPStan\Database\ExplorerTableReturnTypeExtension
		tags: [phpstan.broker.dynamicMethodReturnTypeExtension]
	-
		create: Nette\PHPStan\Database\ActiveRowRelatedReturnTypeExtension
		tags: [phpstan.broker.dynamicMethodReturnTypeExtension]
	-
		create: Nette\PHPStan\Database\ActiveRowRefReturnTypeExtension
		tags: [phpstan.broker.dynamicMethodReturnTypeExtension]
	-
		create: Nette\PHPStan\Database\SelectionInsertReturnTypeExtension
		tags: [phpstan.broker.dynamicMethodReturnTypeExtension]

	# nette/di
	-
		create: Nette\PHPStan\DI\InjectPropertyExtension
		tags: [phpstan.properties.readWriteExtension]

	# nette/forms
	-
		create: Nette\PHPStan\Forms\FormContainerReturnTypeExtension
		tags: [phpstan.broker.dynamicMethodReturnTypeExtension]

	# nette/schema
	-
		create: Nette\PHPStan\Schema\ExpectArrayReturnTypeExtension
		tags: [phpstan.broker.dynamicStaticMethodReturnTypeExtension]

	# nette/tester
	-
		create: Nette\PHPStan\Php\ArrowFunctionVoidIgnoreExtension([
			test
			testException
			testNoError
			Tester\Assert::exception
			Tester\Assert::throws
			Tester\Assert::error
			Tester\Assert::noError
		])
		tags: [phpstan.ignoreErrorExtension]

	-
		create: Nette\PHPStan\Tester\AssertTypeNarrowingExtension
		tags: [phpstan.typeSpecifier.staticMethodTypeSpecifyingExtension]

	# nette/utils
	-
		create: Nette\PHPStan\Utils\StringsRegexHelper
	-
		create: Nette\PHPStan\Utils\FalseToNullReturnTypeExtension
		tags: [phpstan.broker.dynamicStaticMethodReturnTypeExtension]
	-
		create: Nette\PHPStan\Utils\StringsReturnTypeExtension
		tags: [phpstan.broker.dynamicStaticMethodReturnTypeExtension]
	-
		create: Nette\PHPStan\Utils\StringsReplaceClosureTypeExtension
		tags: [phpstan.staticMethodParameterClosureTypeExtension]
	-
		create: Nette\PHPStan\Utils\StringsMatchTypeSpecifyingExtension
		tags: [phpstan.typeSpecifier.staticMethodTypeSpecifyingExtension]
	-
		create: Nette\PHPStan\Utils\ArraysInvokeTypeExtension
		tags: [phpstan.broker.dynamicStaticMethodReturnTypeExtension]
	-
		create: Nette\PHPStan\Utils\HtmlMethodsClassReflectionExtension
		tags: [phpstan.broker.methodsClassReflectionExtension]
	-
		create: Nette\PHPStan\Utils\ValidRegularExpressionRule
		tags: [phpstan.rules.rule]
