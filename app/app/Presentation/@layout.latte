<!DOCTYPE html>
<html>
<head>
	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width">

	<title>{ifset title}{include title|stripHtml} | {/ifset}Moje Oči</title>

	<link rel="stylesheet" href="{$basePath}/assets/bootstrap/css/bootstrap.min.css">
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
	
	<link rel="icon" href="{$basePath}/eye.svg" sizes="any" type="image/svg+xml">

	
	<script src="{$basePath}/assets/formulare/formulare.js"></script>
	<script src="{$basePath}/assets/bootstrap/js/bootstrap.min.js"></script>
	<script src="https://unpkg.com/nette-forms@3"></script>
</head>

<body>
	<header class="bg-primary text-light position-sticky top-0 py-3 mb-4 z-3">
		<div class="container d-flex justify-content-center align-items-center">
			<h1><a n:href=":Home:Home:default" class="text-light text-decoration-none"><i class="bi bi-eye"></i> Moje Oči</a></h1>
		</div>
	</header>

	<div n:snippet="flashes" class="container mt-3 z-3">
		<div n:foreach="$flashes as $flash" class="alert alert-{$flash->type === 'error' ? 'danger' : $flash->type} alert-dismissible fade show shadow-sm text-center" role="alert">
			{$flash->message}
			<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Zavřít"></button>
		</div>
	</div>
	<main class="container my-4 d-flex flex-column align-items-center">
		{ifset title}<h2 class="text-center">{include title}</h2>{/ifset}
		{include content}
	</main>
</body>
<script src="https://unpkg.com/naja@2/dist/Naja.min.js"></script>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        naja.initialize();
    });
</script>
</html>
